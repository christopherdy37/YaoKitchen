generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Inquiry {
  id            String   @id @default(cuid())
  bookingRef    String   @unique
  fullName      String
  mobile        String
  viber         String?
  email         String?
  eventDate     DateTime
  eventLocation String
  package       String
  guestCount    Int
  notes         String?
  status        String   @default("pending")
  source        String   @default("website")
  partnerSlug   String?
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partner Partner? @relation(fields: [partnerSlug], references: [slug])
}

model BlockedDate {
  id          String   @id @default(cuid())
  blockedDate DateTime @unique
  reason      String?
  createdAt   DateTime @default(now())
}

model Partner {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  location  String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  inquiries Inquiry[]
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
